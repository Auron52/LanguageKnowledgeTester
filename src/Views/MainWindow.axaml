<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LanguageKnowledgeTester.Views.MainWindow"
        Title="Language Knowledge Tester"
        Width="720" Height="560"
        MinWidth="520" MinHeight="440"
        KeyDown="Window_KeyDown">

    <DockPanel>

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" Background="#E0E0E0">
            <MenuItem Header="File">
                <MenuItem Header="Load Input File..." Click="LoadInputFile_Click" />
            </MenuItem>
        </Menu>

        <!-- Main quiz area -->
        <StackPanel Margin="36,24,36,24" Spacing="14">

            <!-- Question type label -->
            <SelectableTextBlock Text="{Binding QuestionTypeLabel}"
                                 FontSize="16"
                                 Opacity="0.55" />

            <!-- Question prompt -->
            <SelectableTextBlock FontSize="28"
                                 TextWrapping="Wrap"><Run Text="{Binding QuestionPrefix}" /><Run Text="{Binding QuestionBold}" FontWeight="Bold" /><Run Text="{Binding QuestionSuffix}" /></SelectableTextBlock>

            <!-- Answer input -->
            <TextBox x:Name="AnswerBox"
                     Text="{Binding UserAnswer}"
                     Watermark="Type your answer here..."
                     IsEnabled="{Binding CanSubmit}"
                     FontSize="18"
                     Margin="0,6,0,0" />

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Submit"
                        Click="Submit_Click"
                        IsEnabled="{Binding CanSubmit}"
                        FontSize="18" />
                <Button Content="Next Question"
                        Click="Next_Click"
                        IsEnabled="{Binding CanNext}"
                        FontSize="18" />
                <Button Content="Very Easy — Reduce Frequency"
                        Click="VeryEasy_Click"
                        IsVisible="{Binding ShowVeryEasy}"
                        FontSize="18" />
            </StackPanel>

            <!-- Feedback -->
            <SelectableTextBlock Text="{Binding Feedback}"
                                 TextWrapping="Wrap"
                                 FontSize="18" />

        </StackPanel>
    </DockPanel>
</Window>
